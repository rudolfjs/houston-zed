{
  "name": "houston-zed",
  "version": "0.1.0",
  "private": true,
  "description": "Build tooling for the Houston theme port to Zed",
  "type": "module",
  "scripts": {
    "build": "bun run src/build.ts",
    "local-install": "bun run build && mkdir -p \"$HOME/.config/zed/themes\" && cp themes/houston.json \"$HOME/.config/zed/themes/\"",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "changelog:check": "bash scripts/require-changie-fragment.sh",
    "version:check": "bun run scripts/sync-release-version.mjs --check",
    "version:sync": "bun run scripts/sync-release-version.mjs",
    "validate": "bun run build && bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.4",
    "ajv": "^8.17.1",
    "husky": "^9.1.7",
    "typescript": "^5.6.3"
  }
}
